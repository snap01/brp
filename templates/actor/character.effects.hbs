<section class="actor tab effects {{tab.cssClass}}" data-group="primary" data-tab="effects">
  <div class="effects-grid">
      <div class="diff-label left">{{localize 'BRP.sourceItem'}}</div>
      <div class="diff-label left">{{localize 'EFFECT.FIELDS.name.label'}}</div>
      <div class="diff-label centre">{{localize 'BRP.effect'}}</div>
      <div class="diff-label centre">{{localize 'BRP.amount'}}</div>
      <div class="diff-label centre">{{localize 'BRP.active'}}</div>
    </div>

    <ol class="gr-list">
    {{#each effects as |effect|}}
      <li class="item item-edit effects-grid" data-item-id="{{effect.id}}" data-eff-uuid="{{effect.effUuid}}" data-counter="{{effect.counter}}" {{#if effect.sourceItem}} data-document-class='Item'{{/if}}>
        <div class="effect-source left truncate {{#if effect.sourceItem}}rollable{{/if}}" {{#if effect.sourceItem}} data-tooltip="{{localize 'BRP.viewOnly'}}" data-action="viewDoc" data-preventDel="true"{{/if}}>{{effect.sourceName}}</div>
        <div class="effect-source left truncate">{{effect.effectName}}</div>
        <div class="centre truncate" data-tooltip="{{effect.name}}">{{effect.name}}</div>
        <div class="centre">{{effect.value}}</div>
        {{#if effect.isActive}}
          <div class="centre" data-tooltip="{{localize 'BRP.active'}}">
            <div class="mediumIcon"><i class="item-control fas fa-person-rays"></i></div>
          </div>
        {{else}}
          <div class="centre" data-tooltip="{{localize 'BRP.inactive'}}">
            <div class="mediumIcon fade"><i class="item-control fas fa-person-rays"></i></div>
          </div>
        {{/if}}
      </li>
    {{/each}}
  </ol>

  {{!-- Active Effect Items on Actor --}}
    <br>
    <ol class="gr-list">
      <div class="effects-grid gear-header {{#if singleColour}}primBackCol{{else}}terBackCol{{/if}}">
        <div class="diff-label left" data-tooltip="{{localize 'BRP.effectActorHint'}}">{{localize 'BRP.effectActor'}}</div>
        <div class="diff-label centre">{{localize 'BRP.active'}}</div>
        <div class="centre">
          <a class="item-control item-create" data-tooltip="{{localize 'SIDEBAR.ACTIONS.CREATE.ActiveEffect'}}" data-action="createEffect">
            <i class="fas fa-plus"></i>
          </a>
        </div>
        <div class="centre">
          <a class="" data-tooltip="{{localize 'BRP.clearEffects'}}" data-action="clearEffects">
            <i class="fas fa-broom"></i>
          </a>
        </div>

      </div>
      {{#each actor.effects as |effect|}}
        <li class="item item-edit effects-grid" data-effect-id="{{effect.id}}">
          <div class="effect-source left rollable" data-tooltip="{{localize 'BRP.viewDoc' type=(localize 'DOCUMENT.ActiveEffect')}}" data-action="viewActiveEffect">{{effect.name}}</div>
          <div class="centre" data-tooltip="{{#if effect.active}}{{localize 'BRP.active'}}{{else}}{{localize 'BRP.inactive'}}{{/if}}">
            <a class="item-control item-create mediumIcon{{#unless effect.active}} fade{{/unless}}" data-action="toggleEffect"><i class="item-control fas fa-person-rays"></i></a>
          </div>
        </li>
      {{/each}}
    </ol>
</section>